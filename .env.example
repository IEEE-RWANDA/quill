# Copy to .env.local for local dev, and set the same vars in the Vercel dashboard.

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token — from @BotFather when you create the bot
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# A long random string you invent. Telegram sends it back on every webhook call
# so the function can reject anything that isn't Telegram. e.g. `openssl rand -hex 32`
TELEGRAM_WEBHOOK_SECRET=replace-with-a-long-random-string

# Comma-separated Telegram user IDs allowed to use the bot (get yours from @userinfobot)
ALLOWED_TELEGRAM_USER_IDS=123456789

# GitHub token with Contents + Pull requests read/write on your site repos
# (a fine-grained personal access token is recommended)
GITHUB_TOKEN=github_pat_...

# Only used by the set-webhook script — your deployed function URL
WEBHOOK_URL=https://your-app.vercel.app/api/telegram
